# ============================================
# Village API - Complete Project .gitignore
# ============================================

# ============================================
# Node.js & NPM
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# Environment Variables & Secrets
# ============================================
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local
*.env

# API Keys and Secrets
secrets/
*.key
*.pem
*.cert

# ============================================
# Backend Specific
# ============================================
backend/.env
backend/node_modules/
backend/dist/
backend/build/
backend/logs/
backend/*.log

# Prisma
backend/prisma/migrations/*_migration/
backend/prisma/*.db
backend/prisma/*.db-journal

# ============================================
# Frontend Specific (React + Vite)
# ============================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/build/
frontend/.vite/
frontend/*.local

# ============================================
# Demo Client Specific
# ============================================
demo-client/node_modules/
demo-client/dist/
demo-client/dist-ssr/
demo-client/build/
demo-client/.vite/
demo-client/*.local

# ============================================
# Build & Distribution
# ============================================
dist/
dist-ssr/
build/
out/
*.tsbuildinfo
.cache/

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Operating System Files
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ============================================
# IDEs & Editors
# ============================================

# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.vscode/settings.json
.history/

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
.idea_modules/
out/

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~
.*.sw[a-z]
*.un~
Session.vim

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Eclipse
.project
.classpath
.settings/
.metadata/

# ============================================
# Testing & Coverage
# ============================================
coverage/
*.lcov
.nyc_output/
.coverage/
htmlcov/
.pytest_cache/
.tox/
.hypothesis/

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig

# ============================================
# Database Files
# ============================================
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-shm
*.db-wal

# ============================================
# Compiled Files
# ============================================
*.com
*.class
*.dll
*.exe
*.o
*.so
*.pyc
*.pyo

# ============================================
# Archives
# ============================================
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# ============================================
# Media Files (if not needed in repo)
# ============================================
# Uncomment if you don't want to track media
# *.jpg
# *.jpeg
# *.png
# *.gif
# *.mp4
# *.mp3

# ============================================
# Documentation Build
# ============================================
docs/_build/
site/

# ============================================
# Dependency Directories
# ============================================
jspm_packages/
bower_components/
web_modules/

# ============================================
# TypeScript
# ============================================
*.tsbuildinfo
.tsbuildinfo

# ============================================
# Optional npm cache directory
# ============================================
.npm

# ============================================
# Optional eslint cache
# ============================================
.eslintcache

# ============================================
# Optional stylelint cache
# ============================================
.stylelintcache

# ============================================
# Microbundle cache
# ============================================
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# ============================================
# Optional REPL history
# ============================================
.node_repl_history

# ============================================
# Output of 'npm pack'
# ============================================
*.tgz

# ============================================
# Yarn Integrity file
# ============================================
.yarn-integrity

# ============================================
# parcel-bundler cache
# ============================================
.parcel-cache

# ============================================
# Next.js
# ============================================
.next/
next-env.d.ts

# ============================================
# Nuxt.js
# ============================================
.nuxt/

# ============================================
# Gatsby
# ============================================
.cache/
public/

# ============================================
# Serverless
# ============================================
.serverless/
.webpack/

# ============================================
# FuseBox
# ============================================
.fusebox/

# ============================================
# DynamoDB Local
# ============================================
.dynamodb/

# ============================================
# TernJS
# ============================================
.tern-port

# ============================================
# Stores VSCode versions used for testing
# ============================================
.vscode-test

# ============================================
# Vercel
# ============================================
.vercel

# ============================================
# Turbo
# ============================================
.turbo

# ============================================
# Project Specific
# ============================================

# Large dataset files (uncomment if needed)
# dataset/raw_data/*.xls
# dataset/raw_data/*.ods
# dataset/raw_data/*.zip

# Processed data (keep in repo for now)
# dataset/cleaned_data/
# dataset/final_data/
# dataset/merged_data/

# User uploaded files
uploads/
public/uploads/

# Generated documentation
docs/generated/

# Local development files
.local/
local/

# ============================================
# Keep These Files
# ============================================
!.gitkeep
!.gitignore
!.env.example
!.env.template
